{% set filterItemId = 'filter-productType-' ~ random() %}

{% block wbm_product_type_filter %}
    <div class="filter-multi-select filter-multi-select-productType filter-panel-item{% if sidebar %} d-grid{% else %} dropdown{% endif %}"
         role="listitem"
         data-filter-product-type="true"
         data-filter-product-type-options='{{ {
             name: "productType",
             displayName: "wbm-product-type.storefront.filter.label"|trans|sw_sanitize,
             snippets: {
                 disabledFilterText: "listing.disabledFilterTooltip"|trans|sw_sanitize,
                 ariaLabel: "wbm-product-type.storefront.filter.label"|trans|sw_sanitize,
                 ariaLabelCount: "listing.filterCountAriaLabel"|trans|sw_sanitize
             }
         }|json_encode }}'>

        <button class="filter-panel-item-toggle btn"
                aria-expanded="false"
                aria-label="{{ 'wbm-product-type.storefront.filter.label'|trans|sw_sanitize }}"
                {% if sidebar %}
                data-bs-toggle="collapse"
                data-bs-target="#{{ filterItemId }}"
                {% else %}
                data-bs-toggle="dropdown"
                data-boundary="viewport"
                data-bs-offset="0,8"
                {% endif %}>

            {{ 'wbm-product-type.storefront.filter.label'|trans|sw_sanitize }}

            <span class="filter-multi-select-count"></span>

            {% sw_icon 'arrow-medium-down' style {
                'pack': 'solid', 'size': 'xs', 'class': 'filter-panel-item-toggle'
            } %}
        </button>

        <div class="filter-multi-select-dropdown filter-panel-item-dropdown{% if sidebar %} collapse{% else %} dropdown-menu{% endif %}"
             id="{{ filterItemId }}">
            <ul class="filter-multi-select-list" aria-label="{{ 'wbm-product-type.storefront.filter.label'|trans|sw_sanitize }}">
                {% for bucket in productTypes.buckets %}
                    {% set safeId = 'productType-' ~ bucket.key|replace({' ': '-'})|lower %}
                    <li class="filter-multi-select-list-item">
                        <div class="form-check">
                            <input type="checkbox"
                                   class="form-check-input filter-multi-select-checkbox"
                                   data-label="{{ bucket.key }}"
                                   data-value="{{ bucket.key }}"
                                   value="{{ bucket.key }}"
                                   id="{{ safeId }}">
                            <label class="filter-multi-select-item-label form-check-label"
                                   for="{{ safeId }}">
                                {{ bucket.key }}
                            </label>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>
{% endblock %}
